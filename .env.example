# Database
DATABASE_URL=postgresql+psycopg://orchestrator:orchestrator@localhost:5432/orchestrator

# Document conversion
DOCLING_BASE_URL=http://localhost:5001

# OpenSearch
OPENSEARCH_HOST=http://localhost:9200
OPENSEARCH_INDEX_PREFIX=rag

# Scheduler intervals (minutes)
SCAN_INTERVAL_MINUTES=15
PARSE_INTERVAL_MINUTES=5
TRANSLATE_INTERVAL_MINUTES=5
INDEX_INTERVAL_MINUTES=5

# Translation / enrichment
MAX_TRANSLATION_RETRIES=3
CHUNK_SIZE=1000
CHUNK_OVERLAP=100
ENRICHMENT_MODEL=local:qwen2.5:7b
OLLAMA_HOST=http://host.docker.internal:11434

# OpenRouter (optional — if using openrouter: model prefix)
# OPENROUTER_API_KEY=sk-or-...

# MCP server
MCP_PORT=9700

# App
DEFAULT_OWNER_USERNAME=default
INPUT_DIR=/data/inputs
